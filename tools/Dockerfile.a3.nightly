FROM quay.io/ascend/vllm-ascend:main-a3

ARG PIP_INDEX_URL="https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple"
ARG COMPILE_CUSTOM_KERNELS=1

COPY . /vllm-workspace/vllm-ascend/
# Define environments
ENV DEBIAN_FRONTEND=noninteractive
ENV COMPILE_CUSTOM_KERNELS=${COMPILE_CUSTOM_KERNELS}
ENV BENCHMARK_HOME=/vllm-workspace/vllm-ascend/benchmark

RUN pip config set global.index-url ${PIP_INDEX_URL}

WORKDIR /workspace

# Install ais_bench
RUN git clone --depth 1 -b v3.0-20250930-master https://gitee.com/aisbench/benchmark.git ${BENCHMARK_HOME} && \
    python3 -m pip install -v -e ${BENCHMARK_HOME} \
    -r ${BENCHMARK_HOME}/requirements/api.txt \
    -r ${BENCHMARK_HOME}/requirements/extra.txt

# Install vllm-ascend
# Append `libascend_hal.so` path (devlib) to LD_LIBRARY_PATH
RUN export PIP_EXTRA_INDEX_URL=https://mirrors.huaweicloud.com/ascend/repos/pypi && \
    source /usr/local/Ascend/ascend-toolkit/set_env.sh && \
    source /usr/local/Ascend/nnal/atb/set_env.sh && \
    export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/usr/local/Ascend/ascend-toolkit/latest/`uname -i`-linux/devlib && \
    python3 -m pip install -v -e /vllm-workspace/vllm-ascend/ --extra-index https://download.pytorch.org/whl/cpu/ && \
    python3 -m pip install -r /vllm-workspace/vllm-ascend/requirements-dev.txt && \
    python3 -m pip cache purge

CMD ["/bin/bash"]
